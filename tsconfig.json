{
  "compilerOptions": {
    // Bun uses its own module resolution, but we keep this for tsc compatibility
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    // Include Bun's global types (like Bun.serve, etc.)
    "types": ["bun-types"],

    // Output settings (for build:types script)
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,

    // Strict mode - catches bugs at compile time
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Module interop
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
